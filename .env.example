# ── Django core ──────────────────────────────────────────────────────────────
# Generate a strong key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production

# Set to "production" on the server; leave unset for local dev (defaults to "local")
DJANGO_ENV=local

# Comma-separated list of allowed hostnames in production, e.g. fundzi.ir,www.fundzi.ir
DJANGO_ALLOWED_HOSTS=

# ── OTP / Kavenegar ──────────────────────────────────────────────────────────
# Kavenegar REST API key (get from https://panel.kavenegar.com/client/setting/account)
# Leave blank in dev — OTP will be printed to console instead of sent via SMS.
KAVENEGAR_API_KEY=

# The lookup template name configured in your Kavenegar panel
KAVENEGAR_TEMPLATE=fundzi-otp

# Set to True in production to enforce real OTP verification
FUNDZI_OTP_ENABLED=False

# ── Notifications ─────────────────────────────────────────────────────────────
FUNDZI_SMS_NOTIFICATIONS_ENABLED=False
FUNDZI_EMAIL_NOTIFICATIONS_ENABLED=False

# ── Sentry ───────────────────────────────────────────────────────────────────
# Leave blank in dev; set in production to enable error tracking
SENTRY_DSN=

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
